<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.NeriPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#FF121212</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <style name="Theme.NeriPlayer.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF121212</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_neriplayer_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.NeriPlayer</item>
    </style>
</resources>
